<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if page.title %}{{ page.title }} · {% endif %}lykn</title>
  <meta name="description" content="{{ page.description | default: "Lisp Flavoured JavaScript — s-expression syntax compiling to clean, readable JS" }}">
  <meta name="theme-color" content="#1a2b1f">
  <link rel="stylesheet" href="/css/site.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet">
</head>
{%- assign region = '' -%}
{%- if page.permalink == 'index.html' -%}{%- assign region = 'home' -%}{%- endif -%}
{%- if page.permalink contains 'tour/' -%}{%- assign region = 'tour' -%}{%- endif -%}
{%- if page.permalink contains 'reference/' -%}{%- assign region = 'reference' -%}{%- endif -%}
{%- if page.permalink contains 'playground/' -%}{%- assign region = 'playground' -%}{%- endif -%}
{%- if page.permalink contains 'blog/' -%}{%- assign region = 'blog' -%}{%- endif -%}
<body{% if region != '' %} class="region-{{ region }}"{% endif %}>
  <div class="page-wrap">
    <header>
      <nav class="site-nav">
        <a href="/" class="logo">lykn</a>
        <ul class="nav-links">
          <li><a href="/tour/"{% if region == 'tour' %} class="is-current"{% endif %}>Tour</a></li>
          <li><a href="/reference/"{% if region == 'reference' %} class="is-current"{% endif %}>Reference</a></li>
          <li><a href="/playground/"{% if region == 'playground' %} class="is-current"{% endif %}>Playground</a></li>
          <li><a href="/blog/"{% if region == 'blog' %} class="is-current"{% endif %}>Blog</a></li>
          <li><a href="https://github.com/lykn-lang/lykn">GitHub</a></li>
        </ul>
      </nav>
    </header>

    <main>
      {{ page.content }}
    </main>
  </div>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand-col">
          <div class="footer-brand-name">lykn</div>
          <p class="footer-tagline">Lisp Flavoured JavaScript — s-expression syntax compiling to clean, readable JS</p>
        </div>
        <div class="footer-columns">
          <div class="footer-col">
            <div class="footer-col-title">Language</div>
            <ul class="footer-col-list">
              <li><a href="/tour/">Tour</a></li>
              <li><a href="/reference/">Reference</a></li>
              <li><a href="/playground/">Playground</a></li>
              <li><a href="/blog/">Blog</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <div class="footer-col-title">Resources</div>
            <ul class="footer-col-list">
              <li><a href="https://github.com/lykn-lang/lykn">GitHub &#8599;</a></li>
              <li><a href="https://github.com/lykn-lang/lykn/blob/main/LICENSE">License</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <div class="footer-col-title">Cowboys &amp; Beans</div>
            <ul class="footer-col-list">
              <li><a href="https://cnbb.pub">cnbb.pub &#8599;</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="footer-copyright">&copy; 2026 lykn contributors &middot; Apache-2.0</div>
        <div class="footer-meta">
          <a href="https://cnbb.pub">A Cowboys &amp; Beans project</a> &middot; <a href="https://cobalt-org.github.io/">Powered by Cobalt</a>
        </div>
      </div>
    </div>
  </footer>

  <script src="/js/lykn-browser.js"></script>
</body>
</html>
